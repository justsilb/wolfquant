# WolfQuant Configuration
# Copy this to .env and fill in your values

# ── Server ──────────────────────────────────────────
WOLFQUANT_PORT=8080
WOLFQUANT_LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────
WOLFQUANT_DB_PATH=./data/wolfquant.db

# ── Trading ─────────────────────────────────────────
# Total deposits (for P&L calculation — portfolio value minus deposits)
WOLFQUANT_DEPOSITS=0

# Comma-separated ticker symbols to track
WOLFQUANT_TICKERS=SPY,VXX,AAPL,MSFT,GOOGL

# Quote fetch interval in seconds
WOLFQUANT_QUOTE_INTERVAL=15

# Yahoo Finance chart URL template ({sym} is replaced at runtime)
WOLFQUANT_YAHOO_URL=https://query1.finance.yahoo.com/v8/finance/chart/{sym}?interval=1m&range=1d&includePrePost=false

# ── Broker Integration (optional) ───────────────────
# Set if you want to auto-ingest trades from supported brokers
# WOLFQUANT_BROKER=robinhood
# WOLFQUANT_BROKER_ACCOUNT=your_account_number
